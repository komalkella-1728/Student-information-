#include <stdio.h>

// Define structure
struct Student {
    int id;
    char name[50];
    float marks;
};

int main() {
    struct Student s1;

    // Input student details
    printf("Enter Student ID: ");
    scanf("%d", &s1.id);

    printf("Enter Student Name: ");
    scanf("%s", s1.name);

    printf("Enter Student Marks: ");
    scanf("%f", &s1.marks);

    // Display student details
    printf("\n--- Student Details ---\n");
    printf("ID: %d\n", s1.id);
    printf("Name: %s\n", s1.name);
    printf("Marks: %.2f\n", s1.marks);

    return 0;
}
